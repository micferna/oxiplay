// Interface principale d'OxiPlay.
//
// Slint a été retenu (voir docs/ARCHITECTURE.md) pour son rendu GPU natif,
// son empreinte mémoire minimale et son langage déclaratif compilé.

import { Button, Slider, ComboBox, ListView, LineEdit } from "std-widgets.slint";

export struct PlaylistEntry {
    title: string,
    is-current: bool,
}

// Bouton compact à base de texte (icônes unicode).
component ToolButton inherits Rectangle {
    in property <string> text;
    in property <string> tip;
    in property <bool> dark: true;
    in property <bool> active: false;
    callback clicked();

    width: 36px;
    height: 32px;
    border-radius: 6px;
    background: touch.has-hover
        ? (root.dark ? #2c333d : #d8dce2)
        : (root.active ? (root.dark ? #39414d : #ccd2da) : transparent);

    Text {
        text: root.text;
        color: root.dark ? #e8eaed : #1c1e21;
        font-size: 15px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Barre de progression cliquable / glissable.
component SeekBar inherits Rectangle {
    in property <float> progress;
    in property <bool> dark: true;
    in property <bool> enabled: true;
    callback seek(float);

    height: 16px;

    Rectangle {
        y: parent.height / 2 - 2px;
        height: 4px;
        border-radius: 2px;
        background: root.dark ? #3a414c : #c5cad2;

        Rectangle {
            x: 0;
            width: parent.width * max(0.0, min(1.0, root.progress));
            height: parent.height;
            border-radius: 2px;
            background: #ff8a3d;
        }
    }
    Rectangle {
        x: parent.width * max(0.0, min(1.0, root.progress)) - self.width / 2;
        y: parent.height / 2 - self.height / 2;
        width: touch.has-hover || touch.pressed ? 14px : 10px;
        height: self.width;
        border-radius: self.width / 2;
        background: #ff8a3d;
    }
    touch := TouchArea {
        clicked => {
            if (root.enabled) { root.seek(self.mouse-x / self.width); }
        }
        moved => {
            if (root.enabled && self.pressed) { root.seek(self.mouse-x / self.width); }
        }
    }
}

// Une bande verticale de l'égaliseur (gain -12..+12 dB).
component EqBand inherits VerticalLayout {
    in property <string> freq;
    in property <float> gain;
    in property <bool> dark: true;
    callback changed(float);

    spacing: 4px;

    Text {
        text: "\{round(root.gain)}";
        color: root.dark ? #9aa3af : #5b6573;
        font-size: 10px;
        horizontal-alignment: center;
    }
    track := Rectangle {
        horizontal-stretch: 1;
        vertical-stretch: 1;
        min-height: 90px;
        // Rail.
        Rectangle {
            width: 4px;
            height: parent.height;
            background: root.dark ? #3a414c : #c5cad2;
            border-radius: 2px;
        }
        // Repère du 0 dB.
        Rectangle {
            width: 14px;
            height: 2px;
            y: parent.height / 2 - 1px;
            background: root.dark ? #555d68 : #aeb4bd;
        }
        // Curseur : 12 dB en haut, -12 dB en bas.
        Rectangle {
            width: 22px;
            height: 10px;
            y: (parent.height - self.height) * (1 - (root.gain + 12) / 24);
            background: #ff8a3d;
            border-radius: 5px;
        }
        ta := TouchArea {
            moved => {
                if (self.pressed) {
                    root.changed(12 - (self.mouse-y / parent.height) * 24);
                }
            }
            clicked => {
                root.changed(12 - (self.mouse-y / parent.height) * 24);
            }
        }
    }
    Text {
        text: root.freq;
        color: root.dark ? #9aa3af : #5b6573;
        font-size: 10px;
        horizontal-alignment: center;
    }
}

export component MainWindow inherits Window {
    title: "OxiPlay";
    preferred-width: 1180px;
    preferred-height: 720px;
    min-width: 640px;
    min-height: 420px;
    background: root.dark ? #14171c : #f3f4f6;
    icon: @image-url("icon.png");
    default-font-size: 13px;

    // ---- État exposé par Rust -------------------------------------------
    in property <bool> dark: true;
    in property <image> video-frame;
    in property <bool> has-video: false;
    in property <bool> media-loaded: false;
    in property <string> subtitle-text: "";
    in property <int> subtitle-align: 2;   // pavé numérique 1-9 (2 = bas-centre)
    in property <bool> subtitle-bold: false;
    in property <bool> subtitle-italic: false;
    in property <color> subtitle-color: #ffffff;
    in-out property <float> subtitle-scale: 1.0;
    in property <float> progress: 0.0;
    in property <bool> seekable: true;
    in property <string> position-text: "0:00";
    in property <string> duration-text: "0:00";
    in property <bool> playing: false;
    in property <bool> muted: false;
    in property <string> status-text: "";
    in property <string> media-title: "";
    in property <[PlaylistEntry]> playlist-entries: [];
    in property <[string]> audio-tracks: [];
    in property <[string]> subtitle-tracks: [];
    in property <[string]> recent-files: [];
    in property <[string]> chapters: [];
    in-out property <int> audio-track-index: 0;
    in-out property <int> subtitle-track-index: 0;
    in-out property <int> speed-index: 3; // 1.00×
    in-out property <float> volume: 0.8;
    in-out property <bool> playlist-visible: true;
    in property <string> sub-delay-text: "0.0 s";
    in property <string> audio-delay-text: "0.0 s";
    in property <bool> fullscreen: false;
    in-out property <bool> mini: false;
    in-out property <int> repeat-mode: 0; // 0 = off, 1 = toute la liste, 2 = média courant
    in property <[string]> eq-frequencies: [];
    in-out property <[float]> eq-gains: [];
    in-out property <bool> eq-visible: false;
    in property <string> media-info-text: "";
    in-out property <bool> info-visible: false;
    in property <string> stats-text: "";
    in-out property <bool> stats-visible: false;
    in-out property <bool> subs-visible: false;
    in-out property <float> img-brightness: 0.0;
    in-out property <float> img-contrast: 1.0;
    in-out property <float> img-saturation: 1.0;
    in-out property <bool> image-visible: false;

    // ---- Callbacks vers Rust --------------------------------------------
    callback play-pause();
    callback stop-playback();
    callback seek-to(float);          // fraction 0..1
    callback seek-relative(float);    // secondes
    callback previous-item();
    callback next-item();
    callback open-files();
    callback open-bluray();
    callback open-url(string);
    callback open-recent(int);
    callback volume-changed(float);
    callback toggle-mute();
    callback speed-selected(int);
    callback toggle-fullscreen();
    callback take-screenshot();
    callback cycle-rotation();
    callback image-adjust(float, float, float); // luminosité, contraste, saturation
    callback playlist-activate(int);
    callback playlist-remove(int);
    callback playlist-shift(int, int);
    callback playlist-save();
    callback playlist-load();
    callback audio-track-selected(int);
    callback subtitle-track-selected(int);
    callback load-subtitle-file();
    callback sub-delay-adjust(float); // ± secondes
    callback subtitle-scale-adjust(float);
    callback set-subtitle-color(int); // 0xRRGGBB, ou < 0 = style d'origine
    callback toggle-theme();
    callback eq-band-changed(int, float); // bande, gain dB
    callback eq-reset();
    callback eq-preset-selected(int);     // index de préréglage
    callback toggle-mini();
    callback cycle-repeat();
    callback toggle-stats();
    callback audio-delay-adjust(float);   // ± secondes
    callback chapter-selected(int);
    callback step-frame(bool);            // true = avant, false = arrière

    // Chrome (barres, playlist) masqué en plein écran ou en mini-lecteur.
    property <bool> chrome-hidden: root.fullscreen || root.mini;

    property <color> fg: root.dark ? #e8eaed : #1c1e21;
    property <color> fg-dim: root.dark ? #9aa3af : #5b6573;
    property <color> panel: root.dark ? #1b1f26 : #ffffff;

    forward-focus: keys;
    keys := FocusScope {
        key-pressed(event) => {
            if (event.text == " ") { root.play-pause(); return accept; }
            if (event.text == "f" || event.text == "F") { root.toggle-fullscreen(); return accept; }
            if (event.text == "m" || event.text == "M") { root.toggle-mute(); return accept; }
            if (event.text == "s" || event.text == "S") { root.take-screenshot(); return accept; }
            if (event.text == "p" || event.text == "P") { root.toggle-mini(); return accept; }
            if (event.text == "r" || event.text == "R") { root.cycle-repeat(); return accept; }
            if (event.text == "h" || event.text == "H") { root.toggle-stats(); return accept; }
            if (event.text == ".") { root.step-frame(true); return accept; }
            if (event.text == ",") { root.step-frame(false); return accept; }
            if (event.text == Key.RightArrow) { root.seek-relative(10); return accept; }
            if (event.text == Key.LeftArrow) { root.seek-relative(-10); return accept; }
            if (event.text == Key.UpArrow) { root.volume-changed(min(1.25, root.volume + 0.05)); return accept; }
            if (event.text == Key.DownArrow) { root.volume-changed(max(0.0, root.volume - 0.05)); return accept; }
            if (event.text == Key.Escape && root.fullscreen) { root.toggle-fullscreen(); return accept; }
            return reject;
        }

        VerticalLayout {
            spacing: 0;

            // ---- Barre d'outils -----------------------------------------
            if !root.chrome-hidden: Rectangle {
                height: 44px;
                background: root.panel;

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    padding-top: 6px;
                    padding-bottom: 6px;
                    spacing: 6px;

                    ToolButton { text: "📂"; dark: root.dark; clicked => { root.open-files(); } }
                    ToolButton { text: "📀"; tip: "Blu-ray (BDMV)"; dark: root.dark; clicked => { root.open-bluray(); } }
                    if root.recent-files.length > 0: ComboBox {
                        width: 132px;
                        model: root.recent-files;
                        selected => { root.open-recent(self.current-index); }
                    }
                    if root.chapters.length > 0: ComboBox {
                        width: 168px;
                        model: root.chapters;
                        selected => { root.chapter-selected(self.current-index); }
                    }
                    url-input := LineEdit {
                        placeholder-text: "URL réseau (http, https, hls .m3u8, rtsp)…";
                        horizontal-stretch: 1;
                        accepted(text) => { root.open-url(text); self.text = ""; }
                    }
                    ToolButton { text: "📡"; dark: root.dark; clicked => { root.open-url(url-input.text); url-input.text = ""; } }
                    ToolButton { text: "💬"; dark: root.dark; clicked => { root.load-subtitle-file(); } }
                    ToolButton { text: "Aa"; tip: "Style sous-titres"; dark: root.dark; active: root.subs-visible; clicked => { root.subs-visible = !root.subs-visible; } }
                    ToolButton { text: "📷"; dark: root.dark; clicked => { root.take-screenshot(); } }
                    ToolButton {
                        text: "🎛";
                        dark: root.dark;
                        active: root.eq-visible;
                        clicked => { root.eq-visible = !root.eq-visible; }
                    }
                    ToolButton {
                        text: "ℹ";
                        tip: "Infos média";
                        dark: root.dark;
                        active: root.info-visible;
                        clicked => { root.info-visible = !root.info-visible; }
                    }
                    ToolButton { text: "⟳"; tip: "Rotation 90°"; dark: root.dark; clicked => { root.cycle-rotation(); } }
                    ToolButton { text: "🎨"; tip: "Réglages image"; dark: root.dark; active: root.image-visible; clicked => { root.image-visible = !root.image-visible; } }
                    ToolButton { text: "🗗"; tip: "Mini-lecteur"; dark: root.dark; clicked => { root.toggle-mini(); } }
                    ToolButton { text: root.dark ? "☀" : "🌙"; dark: root.dark; clicked => { root.toggle-theme(); } }
                    ToolButton {
                        text: "☰";
                        dark: root.dark;
                        active: root.playlist-visible;
                        clicked => { root.playlist-visible = !root.playlist-visible; }
                    }
                }
            }

            // ---- Zone centrale : vidéo + playlist ------------------------
            HorizontalLayout {
                vertical-stretch: 1;

                // Surface vidéo.
                Rectangle {
                    horizontal-stretch: 1;
                    background: #000000;

                    if root.has-video: Image {
                        width: 100%;
                        height: 100%;
                        source: root.video-frame;
                        image-fit: contain;
                    }
                    if !root.has-video: VerticalLayout {
                        alignment: center;
                        Text {
                            text: root.media-loaded ? "♪ " + root.media-title : "OxiPlay";
                            color: root.media-loaded ? #e8eaed : #3a414c;
                            font-size: root.media-loaded ? 22px : 44px;
                            font-weight: 700;
                            horizontal-alignment: center;
                        }
                    }

                    // Sous-titres texte, positionnés selon l'alignement ASS
                    // (pavé numérique 1-9) : colonne via 1/4/7, 2/5/8, 3/6/9 ;
                    // ligne via 1-3 (bas), 4-6 (milieu), 7-9 (haut).
                    if root.subtitle-text != "": subbox := Rectangle {
                        // Colonne : gauche (1,4,7), centre (2,5,8), droite (3,6,9).
                        property <int> sub-col: mod(root.subtitle-align - 1, 3); // 0,1,2
                        property <int> sub-row:
                            root.subtitle-align >= 7 ? 2
                            : (root.subtitle-align >= 4 ? 1 : 0); // 0=bas,1=milieu,2=haut
                        x: self.sub-col == 0 ? 24px
                            : (self.sub-col == 2 ? parent.width - self.width - 24px
                            : (parent.width - self.width) / 2);
                        y: self.sub-row == 2 ? 28px
                            : (self.sub-row == 1 ? (parent.height - self.height) / 2
                            : parent.height - self.height - 28px);
                        width: sub-text.preferred-width + 24px;
                        height: sub-text.preferred-height + 12px;
                        background: #000000b0;
                        border-radius: 6px;
                        sub-text := Text {
                            x: 12px;
                            y: 6px;
                            width: min(self.preferred-width, root.width - 80px);
                            text: root.subtitle-text;
                            color: root.subtitle-color;
                            font-size: 20px * root.subtitle-scale;
                            font-weight: root.subtitle-bold ? 700 : 400;
                            font-italic: root.subtitle-italic;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }

                    // Double-clic : plein écran.
                    TouchArea {
                        clicked => { root.play-pause(); }
                        double-clicked => { root.toggle-fullscreen(); }
                    }

                    // Panneau égaliseur flottant (au-dessus de la vidéo).
                    if root.eq-visible: Rectangle {
                        x: parent.width - self.width - 16px;
                        y: 16px;
                        width: 372px;
                        height: 276px;
                        background: root.dark ? #11151aF2 : #fafbfcF2;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: root.dark ? #2c333d : #d8dce2;

                        VerticalLayout {
                            padding: 10px;
                            spacing: 6px;

                            HorizontalLayout {
                                spacing: 6px;
                                Text {
                                    text: "Égaliseur (dB)";
                                    color: root.fg;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                ToolButton { text: "⟲"; tip: "À plat"; dark: root.dark; clicked => { root.eq-reset(); } }
                                ToolButton { text: "✕"; dark: root.dark; clicked => { root.eq-visible = false; } }
                            }
                            ComboBox {
                                height: 26px;
                                model: ["Préréglage…", "Plat", "Rock", "Pop", "Jazz", "Classique", "Graves+", "Voix"];
                                selected => { root.eq-preset-selected(self.current-index); }
                            }
                            HorizontalLayout {
                                vertical-stretch: 1;
                                spacing: 2px;
                                for gain[idx] in root.eq-gains: EqBand {
                                    horizontal-stretch: 1;
                                    dark: root.dark;
                                    gain: gain;
                                    freq: idx < root.eq-frequencies.length ? root.eq-frequencies[idx] : "";
                                    changed(g) => {
                                        root.eq-gains[idx] = g;
                                        root.eq-band-changed(idx, g);
                                    }
                                }
                            }
                        }
                    }

                    // HUD de statistiques (touche H) : coin haut-droit.
                    if root.stats-visible: Rectangle {
                        x: parent.width - self.width - 12px;
                        y: 12px;
                        width: stats-txt.preferred-width + 16px;
                        height: stats-txt.preferred-height + 10px;
                        background: #000000c0;
                        border-radius: 6px;
                        stats-txt := Text {
                            x: 8px;
                            y: 5px;
                            text: root.stats-text;
                            color: #7cfc00;
                            font-size: 12px;
                        }
                    }

                    // Panneau d'informations média (à la demande, touche ℹ).
                    if root.info-visible: Rectangle {
                        x: 16px;
                        y: 16px;
                        width: 400px;
                        height: 200px;
                        background: root.dark ? #11151aF2 : #fafbfcF2;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: root.dark ? #2c333d : #d8dce2;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;
                            HorizontalLayout {
                                Text {
                                    text: "Informations média";
                                    color: root.fg;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                ToolButton { text: "✕"; dark: root.dark; clicked => { root.info-visible = false; } }
                            }
                            Text {
                                text: root.media-info-text == "" ? "Aucun média ouvert." : root.media-info-text;
                                color: root.fg-dim;
                                wrap: word-wrap;
                                vertical-stretch: 1;
                            }
                        }
                    }

                    // Panneau de style des sous-titres (taille + couleur).
                    if root.subs-visible: Rectangle {
                        x: 16px;
                        y: 16px;
                        width: 340px;
                        height: 156px;
                        background: root.dark ? #11151aF2 : #fafbfcF2;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: root.dark ? #2c333d : #d8dce2;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 10px;
                            HorizontalLayout {
                                Text {
                                    text: "Sous-titres";
                                    color: root.fg;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                ToolButton { text: "✕"; dark: root.dark; clicked => { root.subs-visible = false; } }
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                Text { text: "Taille"; color: root.fg-dim; vertical-alignment: center; horizontal-stretch: 1; }
                                ToolButton { text: "−"; dark: root.dark; width: 28px; clicked => { root.subtitle-scale-adjust(-0.1); } }
                                Text { text: "\{round(root.subtitle-scale * 100)} %"; color: root.fg; vertical-alignment: center; }
                                ToolButton { text: "+"; dark: root.dark; width: 28px; clicked => { root.subtitle-scale-adjust(0.1); } }
                            }
                            HorizontalLayout {
                                spacing: 8px;
                                Text { text: "Couleur"; color: root.fg-dim; vertical-alignment: center; horizontal-stretch: 1; }
                                Rectangle {
                                    width: 26px; height: 26px; border-radius: 5px; background: #ffffff;
                                    border-width: 1px; border-color: #888888;
                                    TouchArea { clicked => { root.set-subtitle-color(16777215); } }
                                }
                                Rectangle {
                                    width: 26px; height: 26px; border-radius: 5px; background: #ffff00;
                                    TouchArea { clicked => { root.set-subtitle-color(16776960); } }
                                }
                                Rectangle {
                                    width: 26px; height: 26px; border-radius: 5px; background: #00ffff;
                                    TouchArea { clicked => { root.set-subtitle-color(65535); } }
                                }
                                Rectangle {
                                    width: 26px; height: 26px; border-radius: 5px; background: #00ff00;
                                    TouchArea { clicked => { root.set-subtitle-color(65280); } }
                                }
                                ToolButton { text: "ASS"; tip: "Style d'origine"; dark: root.dark; clicked => { root.set-subtitle-color(-1); } }
                            }
                        }
                    }

                    // Panneau de réglages d'image (luminosité/contraste/saturation).
                    if root.image-visible: Rectangle {
                        x: 16px;
                        y: 16px;
                        width: 320px;
                        height: 232px;
                        background: root.dark ? #11151aF2 : #fafbfcF2;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: root.dark ? #2c333d : #d8dce2;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 6px;
                            HorizontalLayout {
                                Text {
                                    text: "Image";
                                    color: root.fg;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                ToolButton {
                                    text: "⟲";
                                    tip: "Réinitialiser";
                                    dark: root.dark;
                                    clicked => {
                                        root.img-brightness = 0;
                                        root.img-contrast = 1;
                                        root.img-saturation = 1;
                                        root.image-adjust(0, 1, 1);
                                    }
                                }
                                ToolButton { text: "✕"; dark: root.dark; clicked => { root.image-visible = false; } }
                            }
                            Text { text: "Luminosité"; color: root.fg-dim; font-size: 11px; }
                            Slider {
                                minimum: -1.0;
                                maximum: 1.0;
                                value <=> root.img-brightness;
                                changed(v) => { root.image-adjust(v, root.img-contrast, root.img-saturation); }
                            }
                            Text { text: "Contraste"; color: root.fg-dim; font-size: 11px; }
                            Slider {
                                minimum: 0.0;
                                maximum: 2.0;
                                value <=> root.img-contrast;
                                changed(v) => { root.image-adjust(root.img-brightness, v, root.img-saturation); }
                            }
                            Text { text: "Saturation"; color: root.fg-dim; font-size: 11px; }
                            Slider {
                                minimum: 0.0;
                                maximum: 3.0;
                                value <=> root.img-saturation;
                                changed(v) => { root.image-adjust(root.img-brightness, root.img-contrast, v); }
                            }
                        }
                    }

                    // Contrôles flottants du mini-lecteur (apparaissent au survol).
                    if root.mini: mini-bar := Rectangle {
                        x: (parent.width - self.width) / 2;
                        y: parent.height - self.height - 10px;
                        width: 168px;
                        height: 40px;
                        border-radius: 8px;
                        background: mini-hover.has-hover ? #000000d0 : #00000060;
                        opacity: mini-hover.has-hover ? 1.0 : 0.5;

                        mini-hover := TouchArea {
                            HorizontalLayout {
                                alignment: center;
                                padding: 4px;
                                spacing: 4px;
                                ToolButton { text: "⏮"; dark: true; clicked => { root.previous-item(); } }
                                ToolButton { text: root.playing ? "⏸" : "▶"; dark: true; clicked => { root.play-pause(); } }
                                ToolButton { text: "⏭"; dark: true; clicked => { root.next-item(); } }
                                ToolButton { text: "🗖"; tip: "Quitter le mini-lecteur"; dark: true; clicked => { root.toggle-mini(); } }
                            }
                        }
                    }
                }

                // Panneau playlist.
                if root.playlist-visible && !root.chrome-hidden: Rectangle {
                    width: 290px;
                    background: root.panel;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 6px;

                        Text {
                            text: "Liste de lecture";
                            color: root.fg;
                            font-size: 14px;
                            font-weight: 700;
                        }

                        ListView {
                            vertical-stretch: 1;
                            for entry[idx] in root.playlist-entries: Rectangle {
                                height: 34px;
                                border-radius: 6px;
                                background: entry.is-current
                                    ? (root.dark ? #324055 : #dce7f5)
                                    : (row-touch.has-hover ? (root.dark ? #232932 : #eef0f3) : transparent);

                                row-touch := TouchArea {
                                    clicked => { root.playlist-activate(idx); }
                                }
                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 4px;
                                    spacing: 2px;
                                    Text {
                                        text: entry.title;
                                        color: root.fg;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-stretch: 1;
                                    }
                                    ToolButton { text: "▲"; dark: root.dark; width: 24px; clicked => { root.playlist-shift(idx, -1); } }
                                    ToolButton { text: "▼"; dark: root.dark; width: 24px; clicked => { root.playlist-shift(idx, 1); } }
                                    ToolButton { text: "✕"; dark: root.dark; width: 24px; clicked => { root.playlist-remove(idx); } }
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 6px;
                            Button { text: "Ajouter…"; clicked => { root.open-files(); } }
                            Button { text: "💾"; clicked => { root.playlist-save(); } }
                            Button { text: "📥"; clicked => { root.playlist-load(); } }
                        }
                    }
                }
            }

            // ---- Barre de progression ------------------------------------
            if !root.mini: Rectangle {
                height: 28px;
                background: root.panel;
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 10px;
                    Text {
                        text: root.position-text;
                        color: root.fg-dim;
                        vertical-alignment: center;
                        width: 56px;
                    }
                    SeekBar {
                        horizontal-stretch: 1;
                        progress: root.progress;
                        dark: root.dark;
                        enabled: root.seekable && root.media-loaded;
                        seek(f) => { root.seek-to(f); }
                    }
                    Text {
                        text: root.duration-text;
                        color: root.fg-dim;
                        vertical-alignment: center;
                        horizontal-alignment: right;
                        width: 56px;
                    }
                }
            }

            // ---- Contrôles ------------------------------------------------
            if !root.mini: Rectangle {
                height: 52px;
                background: root.panel;

                HorizontalLayout {
                    padding-left: 10px;
                    padding-right: 10px;
                    padding-top: 8px;
                    padding-bottom: 8px;
                    spacing: 6px;

                    ToolButton { text: "⏮"; tip: "Précédent"; dark: root.dark; clicked => { root.previous-item(); } }
                    ToolButton { text: "⏪"; tip: "-10 s"; dark: root.dark; clicked => { root.seek-relative(-10); } }
                    ToolButton {
                        text: root.playing ? "⏸" : "▶";
                        dark: root.dark;
                        width: 44px;
                        clicked => { root.play-pause(); }
                    }
                    ToolButton { text: "⏹"; tip: "Stop"; dark: root.dark; clicked => { root.stop-playback(); } }
                    ToolButton { text: "⏩"; tip: "+10 s"; dark: root.dark; clicked => { root.seek-relative(10); } }
                    ToolButton { text: "⏭"; tip: "Suivant"; dark: root.dark; clicked => { root.next-item(); } }
                    ToolButton {
                        text: root.repeat-mode == 2 ? "🔂" : "🔁";
                        tip: "Répétition (R)";
                        dark: root.dark;
                        active: root.repeat-mode != 0;
                        clicked => { root.cycle-repeat(); }
                    }

                    Rectangle { width: 10px; }

                    Text { text: "Vitesse"; color: root.fg-dim; vertical-alignment: center; }
                    ComboBox {
                        width: 92px;
                        model: ["0.25×", "0.50×", "0.75×", "1.00×", "1.25×", "1.50×", "2.00×", "3.00×", "4.00×"];
                        current-index <=> root.speed-index;
                        selected => { root.speed-selected(self.current-index); }
                    }

                    Text { text: "Audio"; color: root.fg-dim; vertical-alignment: center; }
                    ComboBox {
                        width: 130px;
                        model: root.audio-tracks;
                        current-index <=> root.audio-track-index;
                        selected => { root.audio-track-selected(self.current-index); }
                    }

                    Text { text: "ST"; color: root.fg-dim; vertical-alignment: center; }
                    ComboBox {
                        width: 130px;
                        model: root.subtitle-tracks;
                        current-index <=> root.subtitle-track-index;
                        selected => { root.subtitle-track-selected(self.current-index); }
                    }
                    ToolButton { text: "−"; tip: "ST plus tôt"; dark: root.dark; width: 24px; clicked => { root.sub-delay-adjust(-0.5); } }
                    Text { text: root.sub-delay-text; color: root.fg-dim; vertical-alignment: center; }
                    ToolButton { text: "+"; tip: "ST plus tard"; dark: root.dark; width: 24px; clicked => { root.sub-delay-adjust(0.5); } }

                    Text { text: "A/V"; color: root.fg-dim; vertical-alignment: center; }
                    ToolButton { text: "−"; tip: "Audio plus tôt"; dark: root.dark; width: 24px; clicked => { root.audio-delay-adjust(-0.1); } }
                    Text { text: root.audio-delay-text; color: root.fg-dim; vertical-alignment: center; }
                    ToolButton { text: "+"; tip: "Audio plus tard"; dark: root.dark; width: 24px; clicked => { root.audio-delay-adjust(0.1); } }

                    Rectangle { horizontal-stretch: 1; }

                    Text {
                        text: root.status-text;
                        color: root.fg-dim;
                        vertical-alignment: center;
                        overflow: elide;
                        max-width: 260px;
                    }

                    ToolButton {
                        text: root.muted ? "🔇" : "🔊";
                        dark: root.dark;
                        clicked => { root.toggle-mute(); }
                    }
                    Slider {
                        width: 110px;
                        minimum: 0.0;
                        maximum: 1.25;
                        value <=> root.volume;
                        changed(v) => { root.volume-changed(v); }
                    }
                    ToolButton { text: "⛶"; tip: "Plein écran"; dark: root.dark; clicked => { root.toggle-fullscreen(); } }
                }
            }
        }
    }
}
